<scene version="2.0.0">
    <default name="medium_filename" value="/path/to/SMmi39/data/scenes/common/volumes/sigma_t-constant-sand-256-256-256.vol"/>
    <default name="albedo_filename" value="/path/to/SMmi39/data/scenes/common/volumes/albedo-constant-sand-256-256-256.vol"/>
    <default name="emission_filename" value="/path/to/SMmi39/data/scenes/common/volumes/albedo-constant-sand-256-256-256.vol"/>
    <default name="medium_fixed_max" value="false"/>
    <default name="medium_scale" value="60"/>
    <default name="majorant_resolution_factor" value="0"/>
    <default name="density_activation" value="none"/>
    <default name="majorant_factor" value="1.01"/>
    <default name="use_bbox_fast_path" value="false"/>

    <boolean name="use_bbox_fast_path" value="$use_bbox_fast_path"/>
    <include filename="./common-mi39.xml"/>
    
    <!-- <boolean name="use_bbox_fast_path" value="false"/> -->

    <medium id="medium1" type="heterogeneous">
        <float name="scale" value="$medium_scale"/>
        
        

        <phase type="isotropic" />
        <volume name="sigma_t" type="gridvolume">
            <boolean name="accel" value="false"/>
            <transform name="to_world">
                <scale value="2.0, 2.0, 2.0"/>
                <translate value="-1.0, -1.0, -1.0"/>
                <!-- <scale value="2.0, 2.0, 2.0"/> -->
            </transform>
            
            
            <string name="filename" value="$medium_filename"/>
        </volume>

        <volume name="albedo" type="gridvolume">
            <boolean name="accel" value="false"/>
            <transform name="to_world">
                <scale value="2.0, 2.0, 2.0"/>
                <translate value="-1.0, -1.0, -1.0"/>
                <!-- <scale value="2.0, 2.0, 2.0"/> -->
            </transform>
            
            <string name="filename" value="$albedo_filename"/>
        </volume>

        <boolean name="sample_emitters" value="true"/>
        <boolean name="has_spectral_extinction" value="false"/>
        <integer name="majorant_resolution_factor" value="$majorant_resolution_factor"/>
        <float name="majorant_factor" value="$majorant_factor"/>
        
    </medium>
    <shape type="obj">
        <string name="filename" value="/path/to/SMmi39/data/scenes/common/meshes/cube_unit.obj"/>
        <bsdf type="null"/>
        <ref id="medium1" name="interior"/>

        <transform name="to_world">
            <scale value="2.0, 2.0, 2.0"/>
            <translate value="-1.0, -1.0, -1.0"/>
            <!-- <scale value="2.0, 2.0, 2.0"/> -->
        </transform>
    </shape>
</scene>
